---
layout: layouts/blog-listing.njk
title: Blog
description: Practical guides, updates, and website advice for Fraser Coast businesses.
permalink: /blog/
---
<section class="section-pad" style="padding-top: 140px;">
    <div class="container mx-auto px-4">
        <div class="prose-narrow" style="max-width: 880px;">
            <p class="eyebrow">Notes &middot; Fraser Coast</p>
            <h1 class="display" style="margin-bottom: 24px;">Anchor Web Co. Blog</h1>
            <p class="body-muted" style="max-width: 56ch;">Practical notes on websites, SEO, and lead generation for Fraser Coast businesses.</p>
        </div>
    </div>
</section>

<section class="section-pad" style="padding-top: 0;">
    <div class="container mx-auto px-4">
        <div class="max-w-6xl mx-auto">
            {% if publishedBlogPosts.length %}
            <div class="blog-listing">
                {% for post in publishedBlogPosts %}
                <article class="blog-card">
                    {% if post.featuredImage %}
                    <a href="{{ post.url }}" class="blog-card__image-link">
                        <img class="blog-card__image" src="{{ post.featuredImage }}" alt="{{ post.title }}">
                    </a>
                    {% endif %}
                    <div class="blog-card__content">
                        <p class="blog-card__meta">
                            <time datetime="{{ post.date | dateToISO }}">{{ post.date | readableDate }}</time>
                        </p>
                        <h2 class="blog-card__title">
                            <a href="{{ post.url }}">{{ post.title }}</a>
                        </h2>
                        <p class="blog-card__excerpt">{{ post.description }}</p>
                        <a href="{{ post.url }}" class="blog-card__link">Read article &rarr;</a>
                    </div>
                </article>
                {% endfor %}
            </div>
            {% else %}
            <div class="blog-empty">
                <p>No posts yet - check back soon.</p>
            </div>
            {% endif %}
        </div>
    </div>
</section>
